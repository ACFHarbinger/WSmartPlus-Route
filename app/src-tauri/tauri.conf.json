{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WSmart-Route Studio",
  "version": "0.1.0",
  "identifier": "com.wsmart-route.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "WSmart-Route Studio",
        "width": 1600,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "msi", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "shortDescription": "Desktop control tower for WSmart-Route simulations and training",
    "longDescription": "WSmart-Route Studio is a Tauri desktop application for launching simulations, monitoring training runs, browsing output artefacts, and analysing benchmark results.",
    "category": "Science",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": [],
        "section": "science"
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "store": {},
    "notification": {},
    "dialog": {},
    "shell": {
      "open": true
    }
  }
}
