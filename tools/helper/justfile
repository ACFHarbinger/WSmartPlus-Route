# WSmart+ Route — Helper: general-purpose commands and shortcuts

set unstable := true
set working-directory := '../..'

red := '\033[0;31m'
green := '\033[0;32m'
yellow := '\033[0;33m'
blue := '\033[0;34m'
purple := '\033[0;35m'
cyan := '\033[0;36m'
bold := '\033[1m'
reset := '\033[0m'

[private]
