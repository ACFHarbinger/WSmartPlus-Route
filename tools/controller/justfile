# WSmart+ Route вЂ” Controller: Hydra-based execution commands

set unstable := true
set working-directory := '../..'

# Train a model with Hydra configs

# Usage: just controller::train problem=wcvrp model=am
train problem="" model="" encoder="" decoder="" batch_size="" temporal_horizon="":
    @printf "\033[0;36mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\033[0m\n"
    @printf "\033[0;36mв•‘\033[0m \033[1m%-58s\033[0m   \033[0;36mв•‘\033[0m\n" "рџљЂ STARTING HYDRA TRAINING SESSION"
    @printf "\033[0;36mв• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј\033[0m\n"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Problem:" "{{ problem }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Model:" "{{ model }} ({{ encoder }})"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Batch Size:" "{{ batch_size }}"
    @printf "\033[0;36mв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\033[0m\n"
    export PYTORCH_CUDA_ALLOC_CONF="expandable_segments:True" && \
    uv run python main.py train \
        envs={{ problem }} \
        models={{ model }} \
        model.encoder.type={{ encoder }} \
        hpo.n_trials=0 \
        train.batch_size={{ batch_size }}

# Run model evaluation with Hydra configs

# Usage: just controller::eval model_path=./weights/best.pt dataset=data/test.pkl problem=wcvrp strategy=greedy
eval model_path="" dataset="" problem="" strategy="" samples="":
    @printf "\033[0;36mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\033[0m\n"
    @printf "\033[0;36mв•‘\033[0m \033[1m%-58s\033[0m   \033[0;36mв•‘\033[0m\n" "рџ“Љ STARTING MODEL EVALUATION"
    @printf "\033[0;36mв• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј\033[0m\n"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Model Path:" "{{ model_path }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Dataset:" "{{ dataset }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Problem:" "{{ problem }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Strategy:" "{{ strategy }}"
    @printf "\033[0;36mв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\033[0m\n"
    uv run python main.py eval \
        eval.policy.model.load_path={{ model_path }} \
        eval.datasets=[{{ dataset }}] \
        eval.problem={{ problem }} \
        eval.val_size={{ samples }} \
        eval.decoding.strategy={{ strategy }}

# Run simulator testing with Hydra configs

# Usage: just controller::test-sim policies="vrpp,alns" area=figueiradafoz num_loc=350 sim_distribution=gamma3
test-sim policies="" area="" samples="" n_cores="" num_loc="" sim_distribution="":
    @printf "\033[0;36mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\033[0m\n"
    @printf "\033[0;36mв•‘\033[0m \033[1m%-58s\033[0m   \033[0;36mв•‘\033[0m\n" "рџ§Є STARTING SIMULATION TESTING"
    @printf "\033[0;36mв• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј\033[0m\n"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Policies:" "{{ policies }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Area:" "{{ area }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Num Loc:" "{{ num_loc }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Distribution:" "{{ sim_distribution }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Samples:" "{{ samples }}"
    @printf "\033[0;36mв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\033[0m\n"
    uv run python main.py test_sim \
        sim.policies=[{{ policies }}] \
        sim.n_samples={{ samples }} \
        sim.graph.area={{ area }} \
        sim.graph.num_loc={{ num_loc }} \
        sim.data_distribution={{ sim_distribution }} \
        sim.cpu_cores={{ n_cores }}

# Run simulation policy HPO

# Usage: just controller::hpo-sim policy=hgs trials=100 method=nsgaii
hpo-sim policy="" trials="" method="" workers="" selection="" acceptance="" improver="" policy_kw="" selection_kw="" acceptance_kw="" improver_kw="" area="" samples="":
    @printf "\033[0;36mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\033[0m\n"
    @printf "\033[0;36mв•‘\033[0m \033[1m%-58s\033[0m   \033[0;36mв•‘\033[0m\n" "рџ”Ќ STARTING SIMULATION POLICY HPO"
    @printf "\033[0;36mв• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј\033[0m\n"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Policy:" "{{ policy }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Method:" "{{ method }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Trials:" "{{ trials }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Workers:" "{{ workers }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Selection:" "{{ selection }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Acceptance:" "{{ acceptance }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Improver:" "{{ improver }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Policy KW:" "{{ policy_kw }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Selection KW:" "{{ selection_kw }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Acceptance KW:" "{{ acceptance_kw }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Improver KW:" "{{ improver_kw }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Area:" "{{ area }}"
    @printf "\033[0;36mв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\033[0m\n"
    uv run python main.py hpo_sim tracking=hpo_sim \
        hpo_sim.policy_name={{ policy }} \
        hpo_sim.n_trials={{ trials }} \
        hpo_sim.method={{ method }} \
        hpo_sim.num_workers={{ workers }} \
        hpo_sim.selection_name={{ selection }} \
        hpo_sim.acceptance_name={{ acceptance }} \
        hpo_sim.improver_name={{ improver }} \
        hpo_sim.policy_keywords={{ policy_kw }} \
        hpo_sim.selection_keywords={{ selection_kw }} \
        hpo_sim.acceptance_keywords={{ acceptance_kw }} \
        hpo_sim.improver_keywords={{ improver_kw }} \
        hpo_sim.graph.area={{ area }} \
        hpo_sim.graph.n_samples={{ samples }}

# Generate data with Hydra configs

# Usage: just controller::gen-data wcvrp
gen-data problem="":
    @printf "\033[0;36mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\033[0m\n"
    @printf "\033[0;36mв•‘\033[0m \033[1m%-58s\033[0m   \033[0;36mв•‘\033[0m\n" "рџ“Ѓ GENERATING DATASET"
    @printf "\033[0;36mв• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј\033[0m\n"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Problem:" "{{ problem }}"
    @printf "\033[0;36mв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\033[0m\n"
    uv run python main.py gen_data \
        data.problem={{ problem }}

# Run a batch of experiments from a YAML config

# Usage: just controller::batch-run batch_cfg=logic/configs/batch.yaml [dry_run=true] [fail_fast=true]
batch-run batch_cfg="" dry_run="false" fail_fast="false":
    @printf "\033[0;36mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\033[0m\n"
    @printf "\033[0;36mв•‘\033[0m \033[1m%-58s\033[0m   \033[0;36mв•‘\033[0m\n" "рџ“¦ STARTING BATCH RUN"
    @printf "\033[0;36mв• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј\033[0m\n"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Config:" "{{ batch_cfg }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Dry run:" "{{ dry_run }}"
