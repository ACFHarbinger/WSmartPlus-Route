# Remove targeted simulation runs from output artefacts
# Usage:
#   just controller::clean-results results_dir=assets/output/30_days/riomaior_100 distribution=emp constructor=alns
#   just controller::clean-results results_dir=assets/output/30_days/riomaior_100 improver=ftsp dry_run=true
# Parameters:
#   results_dir  вЂ” path to the output folder (required)
#   distribution вЂ” space-separated distribution tags  (emp gamma1 gamma2 gamma3)
#   constructor  вЂ” route constructor(s)               (alns hgs aco_hh bpc psoma вЂ¦)
#   ms_strategy  вЂ” mandatory-selection strategy/ies   (lookahead last_minute regular)
#   improver     вЂ” route improver(s)                  (ftsp rls rds none вЂ¦)
#   dry_run      вЂ” set to "true" to preview without deleting (default: false)
#   quiet        вЂ” set to "true" to suppress per-item output (default: false)

clean-results results_dir="" distribution="" constructor="" ms_strategy="" improver="" dry_run="" quiet="":
    @printf "\033[0;36mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\033[0m\n"
    @printf "\033[0;36mв•‘\033[0m \033[1m%-58s\033[0m   \033[0;36mв•‘\033[0m\n" "рџ§№ CLEANING SIMULATION RESULTS"
    @printf "\033[0;36mв• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј\033[0m\n"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Results Dir:" "{{ results_dir }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Distribution:" "{{ distribution }}"
    @printf "\033[0;36mв•‘\033[0m \033[0;33m%-15s\033[0m \033[0;35m%-42s\033[0m \033[0;36mв•‘\033[0m\n" "Constructor:" "{{ constructor }}"
