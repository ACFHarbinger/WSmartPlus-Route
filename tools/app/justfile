# WSmart+ Route — App: WSmart-Route Studio (Tauri 2.0 + React 19 desktop app)
#
# All commands are run from the repo root (working-directory := '../..').
# The Tauri app source lives in app/ and the Rust backend in app/src-tauri/.

set unstable := true
set working-directory := '../..'

# ── Dependencies ─────────────────────────────────────────────────────────────

# Install JS/TS dependencies (run once after checkout or after package.json changes)
install:
    npm --prefix app install

# ── Development ──────────────────────────────────────────────────────────────

# Start Vite dev server only — opens in the default browser, no native shell
# Useful for rapid UI iteration without rebuilding the Rust backend.
dev:
    npm --prefix app run dev

# Start full Tauri dev build — native window with Vite hot-reload
# Rebuilds the Rust backend on first run; subsequent rebuilds are incremental.
tauri-dev:
    cd app && npm run tauri -- dev

# ── Production ────────────────────────────────────────────────────────────────

# Build a release binary (creates an installer in app/src-tauri/target/release/bundle/)
build:
    cd app && npm run tauri -- build

# ── Code quality ─────────────────────────────────────────────────────────────

# Type-check the TypeScript frontend without emitting files
check:
    npm --prefix app exec -- tsc --noEmit

# Check the Rust backend for errors without producing a binary (fast)
check-rust:
    cd app/src-tauri && cargo check

# Format the Rust backend with rustfmt
fmt-rust:
    cd app/src-tauri && cargo fmt

# ── Preview ──────────────────────────────────────────────────────────────────

# Build the frontend and preview it in the browser (no Tauri shell)
preview: build
    npm --prefix app run preview

# ── Lint / Analysis ──────────────────────────────────────────────────────────

# Run Cargo Clippy (Rust linter) — fails on any warning
clippy:
    cd app/src-tauri && cargo clippy -- -D warnings

# Check for outdated npm dependencies
outdated:
    npm --prefix app outdated

# ── Dependencies ─────────────────────────────────────────────────────────────

# Update all JS/TS dependencies to their latest allowed versions
update:
    npm --prefix app update

# ── Bundle & runtime ─────────────────────────────────────────────────────────

# List built installer bundles (requires a prior `just app::build`)
bundle:
    @ls -lh app/src-tauri/target/release/bundle/ 2>/dev/null \
        || echo "No bundle directory yet — run: just app::build"

# Print the platform-specific Tauri app-data directory (Tauri Store files, logs)
logs-dir:
    @printf "Linux:   ~/.local/share/wsmart-route-studio\n"
    @printf "macOS:   ~/Library/Application Support/com.wsmart-route.studio\n"
    @printf "Windows: %%APPDATA%%\\com.wsmart-route.studio\n"

# Delete persisted Tauri Store data — resets all saved settings (dev/testing only)
reset-data:
    -rm -rf ~/.local/share/wsmart-route-studio
    -rm -rf "$(HOME)/Library/Application Support/com.wsmart-route.studio"

# ── Cleanup ───────────────────────────────────────────────────────────────────

# Remove installed JS dependencies (node_modules) and Vite dist output
clean-js:
    rm -rf app/node_modules app/dist

# Remove the Rust build cache (slow — only needed when Cargo.toml changes)
clean-rust:
    rm -rf app/src-tauri/target

# Remove all build artifacts (JS + Rust)
clean: clean-js clean-rust
